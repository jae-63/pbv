{
  "name": "pbv",
  "publisher": "local",
  "displayName": "PBV",
  "description": "PBV — Programming By Voice: Whisper speech recognition + LLM command interpretation for VSCode",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pbv",
          "title": "PBV",
          "icon": "images/cachepad.svg"
        }
      ]
    },
    "views": {
      "pbv": [
        {
          "id": "pbv.cachePad",
          "name": "Cache Pad"
        }
      ]
    },
    "commands": [
      {
        "command": "pbv.refreshCachePad",
        "title": "PBV: Refresh Cache Pad",
        "icon": "$(refresh)"
      },
      {
        "command": "pbv.cacheCurrentWord",
        "title": "PBV: Cache Word Under Cursor"
      },
      {
        "command": "pbv.clearCachePad",
        "title": "PBV: Clear Cache Pad"
      },
      {
        "command": "pbv.showCommands",
        "title": "PBV: Show Commands",
        "icon": "$(question)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "pbv.refreshCachePad",
          "when": "view == pbv.cachePad",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "key": "ctrl+down",
        "command": "pbv.scrollStep",
        "when": "pbv.scrolling && editorFocus"
      },
      {
        "key": "ctrl+up",
        "command": "pbv.scrollStepBack",
        "when": "pbv.scrolling && editorFocus"
      }
    ],
    "configuration": {
      "title": "PBV",
      "properties": {
        "pbv.port": {
          "type": "number",
          "default": 7890,
          "description": "TCP port the extension listens on for Swift app commands"
        },
        "pbv.maxCacheItems": {
          "type": "number",
          "default": 20,
          "description": "Maximum number of items in the cache pad"
        },
        "pbv.ollamaModel": {
          "type": "string",
          "default": "qwen2.5:3b",
          "description": "Ollama model name to use for voice interpretation (must be pulled locally)"
        },
        "pbv.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Base URL of the local Ollama server"
        },
        "pbv.helpBrowser": {
          "type": "string",
          "default": "",
          "description": "App name to open the 'What can I say?' help page (e.g. \"Google Chrome\"). Leave blank to use the system default."
        },
        "pbv.selectOnTraverse": {
          "type": "boolean",
          "default": false,
          "description": "When traversing matches, select the matched text (true) or just move the cursor to it (false). The navigation bookmark is always auto-set on traversal entry so 'jump back' returns to the pre-traversal position regardless."
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --target=node18",
    "deploy": "npm run compile && cp out/extension.js ~/.vscode/extensions/local.pbv-0.1.0/out/ && cp package.json ~/.vscode/extensions/local.pbv-0.1.0/",
    "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --target=node18 --watch",
    "test": "jest",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.3.0"
  }
}
