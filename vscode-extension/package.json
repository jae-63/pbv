{
  "name": "voice-coder",
  "publisher": "local",
  "displayName": "Voice Coder",
  "description": "Voice coding assistant — cache pad, navigation, mode indicator, Swift app IPC",
  "version": "0.1.0",
  "engines": {"vscode": "^1.85.0"},
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "voiceCoder",
          "title": "Voice Coder",
          "icon": "images/cachepad.svg"
        }
      ]
    },
    "views": {
      "voiceCoder": [
        {
          "id": "voiceCoder.cachePad",
          "name": "Cache Pad"
        }
      ]
    },
    "commands": [
      {
        "command": "voiceCoder.refreshCachePad",
        "title": "Voice Coder: Refresh Cache Pad",
        "icon": "$(refresh)"
      },
      {
        "command": "voiceCoder.cacheCurrentWord",
        "title": "Voice Coder: Cache Word Under Cursor"
      },
      {
        "command": "voiceCoder.clearCachePad",
        "title": "Voice Coder: Clear Cache Pad"
      },
      {
        "command": "voiceCoder.showCommands",
        "title": "Voice Coder: Show Commands",
        "icon": "$(question)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "voiceCoder.refreshCachePad",
          "when": "view == voiceCoder.cachePad",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Voice Coder",
      "properties": {
        "voiceCoder.port": {
          "type": "number",
          "default": 7890,
          "description": "TCP port the extension listens on for Swift app commands"
        },
        "voiceCoder.maxCacheItems": {
          "type": "number",
          "default": 20,
          "description": "Maximum number of items in the cache pad"
        },
        "voiceCoder.ollamaModel": {
          "type": "string",
          "default": "qwen2.5:3b",
          "description": "Ollama model name to use for voice interpretation (must be pulled locally)"
        },
        "voiceCoder.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Base URL of the local Ollama server"
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --target=node18",
    "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --target=node18 --watch",
    "package": "vsce package"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.3.0"
  }
}
